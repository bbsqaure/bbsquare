<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BB Square</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #fff;
      color: #111;
    }

    header {
      background: #000;
      color: #fff;
      padding: 15px 50px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    header h1 {
      font-size: 24px;
    }

    nav a {
      color: white;
      margin-left: 20px;
      text-decoration: none;
      font-size: 16px;
    }

    nav a:hover {
      text-decoration: underline;
    }

    .hero {
      height: 90vh;
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      background: linear-gradient(to right, #000, #444);
      color: white;
    }

    .hero h2 {
      font-size: 48px;
      margin-bottom: 15px;
    }

    .hero p {
      font-size: 18px;
      margin-bottom: 20px;
    }

    .btn {
      padding: 12px 25px;
      background: white;
      color: black;
      border: none;
      cursor: pointer;
      font-weight: bold;
    }

    .section {
      padding: 60px 50px;
      text-align: center;
    }

    .services {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .card {
      width: 250px;
      padding: 20px;
      border: 1px solid #ddd;
      border-radius: 10px;
      transition: 0.3s;
    }

    .card:hover {
      transform: scale(1.05);
    }

    footer {
      background: #000;
      color: #fff;
      text-align: center;
      padding: 20px;
    }
  </style>
</head>

<body>

  <!-- HEADER -->
  <header>
    <h1>BB Square</h1>
    <nav>
      <a href="#">Home</a>
      <a href="#about">About</a>
      <a href="#services">Services</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <!-- HERO SECTION -->
  <section class="hero">
    <div>
      <h2>Welcome to BB Square</h2>
      <p>Building Your Business with Smart Solutions</p>
      <button class="btn">Get Started</button>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section" id="about">
    <h2>About Us</h2>
    <p>BB Square is a modern business solution company helping clients grow with innovation and strategy.</p>
  </section>

  <!-- SERVICES -->
  <section class="section" id="services">
    <h2>Our Services</h2>
    <div class="services">
      <div class="card">
        <h3>Web Design</h3>
        <p>Modern and responsive websites.</p>
      </div>
      <div class="card">
        <h3>Marketing</h3>
        <p>Grow your business online.</p>
      </div>
      <div class="card">
        <h3>Consulting</h3>
        <p>Expert business strategies.</p>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section" id="contact">
    <h2>Contact Us</h2>
    <p>Email: contact@bbsquare.com</p>
    <p>Phone: +91 9876543210</p>
  </section>

  <!-- FOOTER -->
  <footer>
    <p>© 2026 BB Square. All rights reserved.</p>
  </footer>

</body>
</html>
